{
  "name": "nightshift-foundry/laravel-alertstream",
  "description": "A Laravel package for logging and reporting debug information with full stacktrace to multiple channels.",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "alerting", "logging", "debug", "stacktrace"],
  "authors": [
    {
      "name": "Nightshift Foundry",
      "email": "info@nightshift-foundry.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.0|^11.0|^12.0|^13.0",
    "ext-pdo": "*"
  },
  "require-dev": {
    "orchestra/testbench": "^11.1",
    "phpunit/phpunit": "^10.0|^11.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^2.0",
    "larastan/larastan": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "NightshiftFoundry\\AlertStream\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NightshiftFoundry\\AlertStream\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "NightshiftFoundry\\AlertStream\\Providers\\AlertStreamServiceProvider"
      ],
      "aliases": {
        "AlertStream": "NightshiftFoundry\\AlertStream\\Facades\\AlertStream"
      }
    }
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "test": "@phpunit",
    "phpunit": "phpunit",
    "lint": "php-cs-fixer check --diff",
    "lint:fix": "php-cs-fixer fix",
    "analyse": "phpstan analyse --memory-limit=512M",
    "post-install-cmd": ["@prepare"],
    "post-update-cmd": ["@prepare"]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
