#!/usr/bin/env bash
#
# pre-commit hook — runs php-cs-fixer on staged PHP files.
#
# Installed automatically via `composer install` (see composer.json → prepare).
# To skip in an emergency: git commit --no-verify

set -euo pipefail

PHP_CS_FIXER="vendor/bin/php-cs-fixer"

# ── Guard: fixer must be installed ──────────────────────────────────────────
if [ ! -f "$PHP_CS_FIXER" ]; then
    echo "⚠  php-cs-fixer not found. Run 'composer install' first." >&2
    exit 1
fi

# ── Collect staged PHP files ─────────────────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.php$' || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

echo "🔍  Running php-cs-fixer on staged files…"

# ── Run fixer once for all staged files ──────────────────────────────────────
# A single invocation avoids repeated PHP/autoload/config bootstrap overhead.
# The Finder in .php-cs-fixer.dist.php already limits scope to src/, tests/,
# config/ so a full run is fast (~1-2 s).
"$PHP_CS_FIXER" fix --config=.php-cs-fixer.dist.php \
    --allow-risky=yes \
    --quiet 2>/dev/null || true

# Re-stage any files the fixer touched
for FILE in $STAGED; do
    if [ -f "$FILE" ]; then
        git add "$FILE"
    fi
done

echo "✅  Code style OK."

