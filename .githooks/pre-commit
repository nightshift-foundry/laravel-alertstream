#!/usr/bin/env bash
#
# pre-commit hook — runs php-cs-fixer on staged PHP files.
#
# Installed automatically via `composer install` (see composer.json → prepare).
# To skip in an emergency: git commit --no-verify

set -euo pipefail

PHP_CS_FIXER="vendor/bin/php-cs-fixer"

# ── Guard: fixer must be installed ──────────────────────────────────────────
if [ ! -f "$PHP_CS_FIXER" ]; then
    echo "⚠  php-cs-fixer not found. Run 'composer install' first." >&2
    exit 1
fi

# ── Collect staged PHP files ─────────────────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.php$' || true)

if [ -z "$STAGED" ]; then
    exit 0
fi

echo "🔍  Running php-cs-fixer on staged files…"

# ── Run fixer on the working-tree files ──────────────────────────────────────
# We fix in-place so the corrected content is what gets committed, then
# re-stage each file so the fix is included in the commit automatically.
FAILED=0

for FILE in $STAGED; do
    if [ ! -f "$FILE" ]; then
        continue
    fi

    "$PHP_CS_FIXER" fix --config=.php-cs-fixer.dist.php \
        --allow-risky=yes \
        --quiet \
        "$FILE" 2>/dev/null || true

    # Re-stage any file the fixer touched
    git add "$FILE"
done

# ── Final check: fail the commit if violations remain ────────────────────────
OUTPUT=$("$PHP_CS_FIXER" check --config=.php-cs-fixer.dist.php \
    --allow-risky=yes \
    --quiet 2>/dev/null || true)

if [ -n "$OUTPUT" ]; then
    echo ""
    echo "❌  php-cs-fixer found unfixable violations. Please review:" >&2
    echo "$OUTPUT" >&2
    echo ""
    echo "   Run 'composer lint' to see the full diff." >&2
    FAILED=1
fi

if [ "$FAILED" -eq 0 ]; then
    echo "✅  Code style OK."
fi

exit $FAILED

