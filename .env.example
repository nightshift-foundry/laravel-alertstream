# AlertStream Configuration

ALERTSTREAM_ENABLED=true
# Default alert level (debug, info, notice, warning, error, critical, alert, emergency)
ALERTSTREAM_LEVEL=error
ALERTSTREAM_REPORT_EXCEPTIONS=true
ALERTSTREAM_INCLUDE_STACKTRACE=true
# Log delivery channels for log() (comma-separated: slack,teams,discord,mail).
# Logs are always also written to the `alertstream` file (storage/logs/alertstream.log).
ALERTSTREAM_LOG_CHANNELS=

# ── Context ───────────────────────────────────────────
ALERTSTREAM_INCLUDE_HOSTNAME=true
ALERTSTREAM_INCLUDE_ENVIRONMENT=true
ALERTSTREAM_INCLUDE_REQUEST_ID=false

# ── Throttling ────────────────────────────────────────
ALERTSTREAM_THROTTLE=true
ALERTSTREAM_THROTTLE_MAX=5

# ── Queue ─────────────────────────────────────────────
ALERTSTREAM_QUEUE=true
ALERTSTREAM_QUEUE_CONNECTION=
ALERTSTREAM_QUEUE_NAME=default

# ── Active Alert AlertChannels (comma-separated: slack,teams,discord,mail) ──
ALERTSTREAM_CHANNELS=

# ── Slack ─────────────────────────────────────────────
ALERTSTREAM_SLACK_WEBHOOK=

# ── Microsoft Teams ───────────────────────────────────
ALERTSTREAM_TEAMS_WEBHOOK=

# ── Discord ───────────────────────────────────────────
ALERTSTREAM_DISCORD_WEBHOOK=

# ── Mail ──────────────────────────────────────────────
ALERTSTREAM_MAIL_TO=
ALERTSTREAM_MAIL_FROM=

# ── Log Channel Destinations (separate webhooks for Monolog log drivers) ──
ALERTSTREAM_LOG_SLACK_WEBHOOK=
ALERTSTREAM_LOG_TEAMS_WEBHOOK=
ALERTSTREAM_LOG_DISCORD_WEBHOOK=
ALERTSTREAM_LOG_MAIL_TO=
ALERTSTREAM_LOG_MAIL_FROM=

# ── Snapshots ─────────────────────────────────────────
ALERTSTREAM_SNAPSHOTS=false
ALERTSTREAM_SNAPSHOTS_TABLE=alertstream_snapshots
ALERTSTREAM_SNAPSHOTS_RETENTION=30
ALERTSTREAM_SNAPSHOTS_DEDUP_MINUTES=60
ALERTSTREAM_SNAPSHOTS_ROUTE_PREFIX=alertstream

