# AlertStream Configuration

# Enable or disable AlertStream
ALERTSTREAM_ENABLED=true

# Comma-separated list of logging channels to use
ALERTSTREAM_CHANNELS=single

# Default alert level (debug, info, notice, warning, error, critical, alert, emergency)
ALERTSTREAM_LEVEL=alert

# Automatically report exceptions
ALERTSTREAM_REPORT_EXCEPTIONS=true

# Include stacktrace in logs
ALERTSTREAM_INCLUDE_STACKTRACE=true

# Include hostname in context
ALERTSTREAM_INCLUDE_HOSTNAME=true

# Include environment in context
ALERTSTREAM_INCLUDE_ENVIRONMENT=true

# Include request ID in context
ALERTSTREAM_INCLUDE_REQUEST_ID=false

